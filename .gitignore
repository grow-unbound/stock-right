# See https://help.github.com/articles/ignoring-files/

# Dependencies (any workspace package)
node_modules/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
coverage/
.nyc_output/

# Next.js
.next/
out/
.vercel

# Expo / React Native
.expo/
*.orig
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Monorepo / build outputs
.turbo/
dist/
*.tsbuildinfo

# Misc
.DS_Store
*.pem

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local env (keep *.example tracked)
.env
.env*.local

# TypeScript (generated by Next in app dirs; regenerate with dev/build)
next-env.d.ts
