# Copy to .env.local — never commit secrets.
# Expo reads EXPO_PUBLIC_* vars at build time (safe to expose on device).

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# EAS cloud builds do not read .env.local. Set the same EXPO_PUBLIC_* values for
# the Preview (UAT) profile: Expo dashboard → Project → Environment variables,
# or: eas secret:create --scope project --name EXPO_PUBLIC_SUPABASE_URL --value "…"
